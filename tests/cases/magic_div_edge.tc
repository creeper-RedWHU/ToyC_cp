// 优化正确性：magic-number 除法的边界情况
// 验证除数为 1、-1 以及接近 INT_MIN/INT_MAX 附近除数的正确性

int main() {
    int x = 12345;
    int y = -12345;

    // 除数 1：结果等于被除数
    int a = x / 1;    // 12345
    int b = y / 1;    // -12345

    // 除数 -1：结果等于负被除数
    int c = x / -1;   // -12345
    int d = y / -1;   // 12345

    // 除数 1 的模：结果为 0
    int e = x % 1;    // 0
    int f = y % 1;    // 0

    // 验证
    if (a != 12345) return 1;
    if (b != -12345) return 2;
    if (c != -12345) return 3;
    if (d != 12345) return 4;
    if (e != 0) return 5;
    if (f != 0) return 6;

    // 大质数除法（可能需要 64 位中间结果的 magic 数计算）
    int p = 100000 / 10007;   // 9
    int q = 100000 % 10007;   // 100000 - 9*10007 = 100000 - 90063 = 9937
    if (p != 9) return 7;
    if (q != 9937) return 8;

    return 0;   // 全部通过
}

// 测试全局变量、函数参数、局部变量同名时的完整交互
// 每个作用域层级应访问正确的变量

int x = 100;   // 全局 x

int f(int p) {
    // 参数 p 屏蔽全局 x
    int r = p;             // 使用参数 p
    {
        int x = p + 1;     // 内层局部 x = 参数p + 1（用参数 p 初始化，避免自引用 UB）
        r = r + x;         // r = p + (p + 1)
    }
    // 内层块结束，x 在此处指全局 x
    return r + x;          // (p + p + 1) + 全局x(100) = 2p + 1 + 100
}

int g(int p) {
    int x = p * 2;         // 局部 x 屏蔽全局 x，用参数 p 初始化
    return x + 1;          // 局部 x + 1 = p*2 + 1
}

int main() {
    int result_f = f(10);  // 2*10 + 1 + 100 = 121
    int result_g = g(5);   // 5*2 + 1 = 11
    int local_x = x + 1;   // 全局 x = 100, local_x = 101
    return (result_f + result_g + local_x) % 256;
    // 121 + 11 + 101 = 233
}

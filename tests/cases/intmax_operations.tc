// 测试 INT_MAX（2147483647）的各种运算
// ToyC 使用 32 位有符号整数，溢出行为遵循 C 语言补码回绕
int main() {
    int mx = 2147483647;

    // 取模不溢出
    int a = mx % 256;      // 255
    int b = mx % 100;      // 47

    // 除法不溢出
    int c = mx / 2;        // 1073741823
    int d = mx / 1000;     // 2147483

    // 减法（接近但不溢出）
    int e = mx - 1;        // 2147483646
    int f = mx - 1000;     // 2147482647

    // 验证结果（取 %256 避免大数出现）
    int result = a + b + (c % 256) + (d % 256) + (e % 256) + (f % 256);
    // 255 + 47 + (1073741823%256) + (2147483%256) + (2147483646%256) + (2147482647%256)
    // = 255 + 47 + 255 + 155 + 254 + 23 = 989, %256 = 221
    return result % 256;
}

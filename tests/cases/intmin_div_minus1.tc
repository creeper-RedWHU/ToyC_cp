// 测试 INT_MIN / -1 的溢出行为
// C 语言中 INT_MIN / -1 是未定义行为，但 ToyC 测试保证输入不含未定义行为
// 这里测试 INT_MIN 的其他合法运算
int main() {
    int mn = -2147483648;

    // 合法的 INT_MIN 运算
    int a = mn / 2;        // -1073741824
    int b = mn / -2;       // 1073741824 -> %256 = 0
    int c = mn % 3;        // -2147483648 = 3 * (-715827882) + (-2), 即 -2
    int d = mn % -3;       // -2
    int e = mn + 2147483647;  // -1

    return (a % 256 + 256) % 256
         + (b % 256 + 256) % 256
         + (c + 256) % 256
         + (d + 256) % 256
         + (e + 256) % 256;
    // a=-1073741824: a%256=0, (0+256)%256=0
    // b=1073741824:  b%256=0, (0+256)%256=0
    // c=-2:  (c+256)%256=254
    // d=-2:  (d+256)%256=254
    // e=-1:  (e+256)%256=255
    // 结果: 0+0+254+254+255 = 763, exit_code = 763%256 = 251
}

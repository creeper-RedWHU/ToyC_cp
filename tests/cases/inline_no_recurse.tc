// 优化正确性：递归函数不应被内联（防止无限展开）
// 结果与 -opt 和无 -opt 应相同

int fact(int n) {
    if (n <= 1) return 1;
    return n * fact(n - 1);
}

int fib(int n) {
    if (n < 2) return n;
    return fib(n - 1) + fib(n - 2);
}

int main() {
    int a = fact(8) % 256;   // 40320 % 256 = 128
    int b = fib(12) % 256;   // 144
    return (a + b) % 256;    // (128 + 144) % 256 = 16
}

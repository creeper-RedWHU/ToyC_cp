// 测试复杂的死代码场景（DCE 应清除，但不能影响活跃代码）
// return 之后的语句是死代码；不可达的 if 分支也是死代码

int dead_after_if(int x) {
    if (x > 0) {
        return 1;
        x = 999;    // 死代码（紧接 return 后）
    } else {
        return -1;
        x = 888;    // 死代码
    }
    return 0;       // 死代码（两个分支都已返回）
}

int dead_in_loop(int x) {
    int i = 0;
    while (i < x) {
        i = i + 1;
        if (i == 3) {
            return i;
            i = 100;  // 死代码
        }
    }
    return 0;
}

// 常量条件分支（不一定要求编译器消除，但结果必须正确）
int const_branch() {
    int c = 1;
    if (c) {
        return 10;
    } else {
        return 20;   // 运行时不可达
    }
}

int main() {
    int a = dead_after_if(5);   // 1
    int b = dead_after_if(-3);  // -1
    int c = dead_in_loop(10);   // 3
    int d = dead_in_loop(2);    // 0（循环结束前未到 i==3）
    int e = const_branch();     // 10

    return (a + b + c + d + e) % 256;
    // 1 + (-1) + 3 + 0 + 10 = 13
}

// 优化正确性：多路径 return 合并（return coalescing）
// 编译器可能将多个 return 语句合并到单一出口点
// 结果在 -opt 和 无 -opt 下必须相同

int classify(int x) {
    if (x < 0) return 1;
    if (x == 0) return 2;
    if (x < 10) return 3;
    if (x < 100) return 4;
    return 5;
}

int abs_val(int x) {
    if (x < 0) return 0 - x;
    return x;
}

int max3(int a, int b, int c) {
    if (a >= b && a >= c) return a;
    if (b >= a && b >= c) return b;
    return c;
}

int sign(int x) {
    if (x > 0) return 1;
    if (x < 0) return -1;
    return 0;
}

int main() {
    int a = classify(-5) + classify(0) + classify(7) + classify(50) + classify(200);
    // 1 + 2 + 3 + 4 + 5 = 15
    int b = abs_val(-7) + abs_val(0) + abs_val(13);
    // 7 + 0 + 13 = 20
    int c = max3(3, 7, 5) + max3(10, 2, 8) + max3(1, 1, 1);
    // 7 + 10 + 1 = 18
    int d = sign(-5) + sign(0) + sign(3);
    // -1 + 0 + 1 = 0
    return (a + b + c + d) % 256;  // (15 + 20 + 18 + 0) % 256 = 53
}

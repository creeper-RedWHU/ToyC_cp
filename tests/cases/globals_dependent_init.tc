// 测试全局变量与全局常量、运行期依赖赋值
// 全局变量用常量表达式初始化（host C 兼容），依赖关系在函数内建立
const int BASE = 7;
int a = 14;            // BASE * 2，用字面量保证 host C 可编译
int b = 21;            // a + BASE
int c = 28;            // b * 2 - a
int d = 63;            // c + a + b

void modify() {
    a = a + 1;         // 15
    b = b + 1;         // 22
}

int main() {
    modify();
    return (a + b + c + d) % 256;  // 15 + 22 + 28 + 63 = 128
}

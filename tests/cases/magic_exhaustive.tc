int main() {
    int s = 0;
    int a = -400;
    while (a <= 400) {
        s = s + a / 3 + a % 3;
        s = s + a / 5 + a % 5;
        s = s + a / 6 + a % 6;
        s = s + a / 7 + a % 7;
        s = s + a / 9 + a % 9;
        s = s + a / 10 + a % 10;
        s = s + a / 11 + a % 11;
        s = s + a / 12 + a % 12;
        s = s + a / 13 + a % 13;
        s = s + a / 15 + a % 15;
        s = s + a / 17 + a % 17;
        s = s + a / 25 + a % 25;
        s = s + a / 50 + a % 50;
        s = s + a / 99 + a % 99;
        s = s + a / 100 + a % 100;
        s = s + a / 101 + a % 101;
        s = s + a / 127 + a % 127;
        s = s + a / 1000 + a % 1000;
        s = s + a / 12345 + a % 12345;
        s = s + a / 100000 + a % 100000;
        s = s + a / (-3) + a % (-3);
        s = s + a / (-7) + a % (-7);
        s = s + a / (-9) + a % (-9);
        s = s + a / (-13) + a % (-13);
        s = s + a / (-100) + a % (-100);
        s = s + a / (-1000) + a % (-1000);
        s = s + a / (-12345) + a % (-12345);
        a = a + 1;
    }
    return s % 256;
}

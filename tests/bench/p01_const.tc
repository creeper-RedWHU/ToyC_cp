// p01_const — 常量折叠：循环体内大量可在编译期求值的常量算术。
// 优化器应把常量子表达式折叠成一个立即数，循环体只剩累加。
int main() {
    int s = 0;
    int i = 0;
    while (i < 3000000) {
        // 整串常量运算，理论上可折叠为单一常量
        int c = 2 + 3 * 4 - 6 / 2 + 100 % 7 * 8 - (9 - 4) * 2;
        s = s + c + i % 3;
        i = i + 1;
    }
    return s % 256;
}

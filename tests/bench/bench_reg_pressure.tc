// 性能基准：高寄存器压力（测试寄存器分配质量）
// 单个循环体内同时活跃大量变量，需要大量 spill/reload 或高质量着色

int main() {
    int s = 0;
    int i = 0;
    while (i < 1000000) {
        // 同时活跃 20+ 个变量，最大化寄存器压力
        int a0 = i % 13;
        int a1 = i % 17;
        int a2 = i % 19;
        int a3 = i % 23;
        int a4 = i % 29;
        int a5 = i % 31;
        int a6 = i % 37;
        int a7 = i % 41;
        int b0 = a0 + a1;
        int b1 = a2 + a3;
        int b2 = a4 + a5;
        int b3 = a6 + a7;
        int c0 = b0 * b1;
        int c1 = b2 * b3;
        int d  = c0 + c1 + a0 * a7 + a3 * a4;
        s = s + d;
        i = i + 1;
    }
    return s % 256;
}

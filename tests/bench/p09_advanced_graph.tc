// p09_advanced_graph — 图算法风格：用全局数组模拟邻接（ToyC 无数组，用递归+全局变量模拟）。
// 大量函数调用与分支，测试内联与寄存器分配。
int acc = 0;

int step(int node, int depth) {
    if (depth <= 0) return node % 7;
    int a = step((node * 2 + 1) % 97, depth - 1);
    int b = step((node * 3 + 2) % 97, depth - 1);
    return (a + b + node) % 101;
}

int main() {
    int s = 0;
    int i = 0;
    while (i < 4000) {
        s = s + step(i % 97, 8);
        i = i + 1;
    }
    return s % 256;
}
